{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env", "**/.env.local"],
  "tasks": {
    "dev": {
      "cache": false,
      "interactive": false
    },
    "build": {
      "outputs": ["dist/**", "build/**", ".next/**"],
      "cache": true
    },
    "type-check": {
      "cache": true
    },
    "test": {
      "cache": false,
      "interactive": true
    }
  }
}
